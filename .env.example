# ─────────────────────────────────────────────
# Korea Investment & Securities (KIS) Open API
# ─────────────────────────────────────────────
# 운용 모드. paper(모의투자) 또는 live(실전).
# 처음에는 반드시 paper로 시작하고, 최소 4주 검증 후 live로 전환.
KIS_MODE=paper

# 모의투자 계좌
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CD=01

# 실전 계좌
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
KIS_LIVE_ACCOUNT_NO=
KIS_LIVE_ACCOUNT_PRODUCT_CD=01

# ─────────────────────────────────────────────
# Anthropic Claude API
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# Watchtower 자동 업데이트 HTTP API 토큰
# ─────────────────────────────────────────────
# 봇이 Watchtower HTTP API 를 호출할 때 쓰는 인증 토큰.
# 아래 명령으로 랜덤 생성 후 붙여넣기:
#   openssl rand -hex 32
WATCHTOWER_HTTP_TOKEN=change-me-to-random-hex-string

# ─────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────
TZ=Asia/Seoul
LOG_LEVEL=INFO
