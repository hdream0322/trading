# ─────────────────────────────────────────────
# Korea Investment & Securities (KIS) Open API
# ─────────────────────────────────────────────
# 운용 모드. paper(모의투자) 또는 live(실전).
# 처음에는 반드시 paper로 시작하고, 최소 4주 검증 후 live로 전환.
KIS_MODE=paper

# 모의투자 계좌
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CD=01

# 실전 계좌
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
KIS_LIVE_ACCOUNT_NO=
KIS_LIVE_ACCOUNT_PRODUCT_CD=01

# ─────────────────────────────────────────────
# Anthropic Claude API
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────
TZ=Asia/Seoul
LOG_LEVEL=INFO
